# =============================================================================
# AI provider — set ONE of the keys below. If neither is set, every AI feature
# silently falls back to a deterministic template-string mock.
#
# Copy this file to `.env.local` (gitignored) and fill in whichever provider
# you prefer. Restart `npm run dev` after editing.
# =============================================================================

# -------- Option A: Google Gemini (FREE tier — recommended if you don't want to pay) ----------
# Free tier: 1500 requests/day, no credit card required.
# Get a key at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=
# Optional — defaults to gemini-2.5-flash (the free, fast model).
VITE_GEMINI_MODEL=

# -------- Option B: Anthropic Claude (paid, ~$0.001/call on Haiku) ----------
# Get a key at: https://console.anthropic.com/ → API Keys
VITE_ANTHROPIC_API_KEY=
# Optional — defaults to claude-haiku-4-5-20251001 (cheap + fast).
VITE_ANTHROPIC_MODEL=

# If both keys are set, Anthropic wins (presumed intentional).
